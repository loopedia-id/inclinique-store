RewriteEngine On

# 1. Menghilangkan ekstensi .html dari URL secara eksternal
# Contoh: Jika user akses shop.html, maka akan di-redirect ke /shop
RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
RewriteRule ^ %1 [L,R=301]

# 2. Mengarahkan URL tanpa ekstensi ke file .html secara internal
# Cek apakah request bukan berupa direktori
RewriteCond %{REQUEST_FILENAME} !-d
# Cek apakah file .html-nya ada
RewriteCond %{REQUEST_FILENAME}\.html -f
# Jalankan file .html tersebut tanpa mengubah URL di browser
RewriteRule ^(.*)$ $1.html [NC,L]

# 3. Memastikan file gambar dan statis lainnya tetap bisa diakses langsung
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule \.(png|jpg|jpeg|gif|ico|css|js)$ - [NC,L]